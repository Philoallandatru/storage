[global]
ioengine=libaio
direct=1
thread=1
group_reporting=1
size=1G
runtime=30
time_based
ramp_time=2
randrepeat=0

# T1: 128K randread QD=32 (burstgpt 风格,89% 跨100MiB大跳跃读)
[t1_128k_randread_qd32]
rw=randread
bs=128k
iodepth=32
numjobs=1
stonewall

# T2: 128K randwrite QD=32 (write plane 极限)
[t2_128k_randwrite_qd32]
rw=randwrite
bs=128k
iodepth=32
numjobs=1
stonewall

# T3: 128K mixed 90R/10W QD=32 (sharegpt 风格,R/W=15.3:1)
[t3_128k_mixed_90r10w_qd32]
rw=randrw
rwmixread=90
bs=128k
iodepth=32
numjobs=1
stonewall

# T4: 128K mixed 70R/30W QD=32 (default 风格,R/W=7.6:1)
[t4_128k_mixed_70r30w_qd32]
rw=randrw
rwmixread=70
bs=128k
iodepth=32
numjobs=1
stonewall

# T5: QD sweep 128K randread (sharegpt 脉冲+CV=0.61 模拟)
[t5_qd1]
rw=randread
bs=128k
iodepth=1
numjobs=1
runtime=15
stonewall
[t5_qd4]
rw=randread
bs=128k
iodepth=4
numjobs=1
runtime=15
stonewall
[t5_qd16]
rw=randread
bs=128k
iodepth=16
numjobs=1
runtime=15
stonewall
[t5_qd32]
rw=randread
bs=128k
iodepth=32
numjobs=1
runtime=15
stonewall
[t5_qd64]
rw=randread
bs=128k
iodepth=64
numjobs=1
runtime=15
stonewall
[t5_qd128]
rw=randread
bs=128k
iodepth=128
numjobs=1
runtime=15
stonewall

# T6: 4K randread QD=1 (设备底线/文件系统元数据)
[t6_4k_randread_qd1]
rw=randread
bs=4k
iodepth=1
numjobs=1
runtime=15
stonewall
