# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/

# Virtual environments
venv/
.venv/
env/
.env
.env.*
!.env.example
env-*
**/.venv
**/.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.html
vdb_benchmark/vdbbench/benchmark/results/*

# OS files
.DS_Store
Thumbs.db


# Coding Agents
.agent/
.roo/
.vscode/
CLAUDE.md
.roomodes
LOCAL_BRANCH_NOTES.md

# DLIO test artifacts — created in cwd when running dlio_benchmark tests
output/
dlio_test_output/
data/
checkpoints/
dlio_benchmark_test.log
dlio_aistore_benchmark_test.log

# Backup directories — local-only, never commit
Test-Backup/
dlio_benchmark.OLD*/

# Credential / environment files — NEVER commit these
.env
env-fast

# TLS certificates — local only, never commit (paths to certs are in .env)
.certs/

# Benchmark simulation output files
sim_*.tsv
sim_*.tsv.zst

# Sweep run logs and results (local benchmark output)
sweep_logs/
sweep_flux_master.log

# Ignore the entire results/ tree, then whitelist the small static
# assets we want to publish (early baseline reports + visualizations).
results/**
!results/kvcache-profile/
results/kvcache-profile/**
!results/kvcache-profile/report/
!results/kvcache-profile/report/*.pdf
!results/kvcache-profile/report/*.html
!results/kvcache-profile/report/*.md
!results/kvcache-profile/report/*.png
!results/kvcache-profile/report/*.svg
!results/kvcache-profile/report/*.csv
!results/kvcache-profile/visualizations/
!results/kvcache-profile/visualizations/*.xlsx

# Local benchmark datasets and generated storage profiles
datasets/
kv_cache_benchmark/fio_traced_*.ini
kv_cache_benchmark/fio_*.ini
*.bpftrace.txt
*bpftrace*.txt

# Test scripts and helpers not part of the benchmark suite
test_s3dlio_gen_direct.py

# Hydra runtime output (created in cwd when running workloads with hydra config)
hydra_log/

# Timestamped sweep run logs written to repo root by sweep_*.sh scripts
sweep_unet3d_*.log
sweep_dlrm_*.log
sweep_flux_*.log
